APP_ENV=local
JWT_SECRET=replace-with-strong-secret
DEMO_USER_EMAIL=admin@example.com
DEMO_USER_PASSWORD=admin123

# Local default uses sqlite. For containers use postgres service:
# SQLALCHEMY_DATABASE_URL=postgresql+psycopg2://app_user:app_password@postgres:5432/ai_workflow
SQLALCHEMY_DATABASE_URL=sqlite:///./local.db

REDIS_URL=redis://redis:6379/0

# S3/MinIO configuration. Leave blank to use local filesystem storage.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET=

# OpenSearch configuration. Leave blank to use DB fallback text search.
OPENSEARCH_URL=
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=documents

CORS_ORIGINS=http://127.0.0.1:3101,http://localhost:3101
